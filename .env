VITE_SEO_DESCRIPTION="Lenzorah is a powerful movie and TV series streaming and downloading platform built with React, Vite, and Tailwind CSS. It offers a seamless user experience with features like batch downloads, subtitle support, and AI-powered recommendations."
VITE_SEO_KEYWORDS="movies, tv series, downloads, streaming"
VITE_THEME_COLOR="#030305"
VITE_APP_ENV="development"

