# ------------------------------
# API Integrations
# ------------------------------
# Movie API
VITE_API_BASE="https://movieapi.gifted.co.ke"
VITE_API_KEY=gifted_movieapi_789fbud2389889dg8962e098g23d6

# AI (OpenRouter)
VITE_OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
VITE_OPENROUTER_URL="https://openrouter.ai/api/v1/chat/completions"
# ------------------------------
# General Settings
# ------------------------------
VITE_FALLBACK_POSTER="https://placehold.co/600x900?text=No+Poster"
VITE_FALLBACK_BACKDROP="https://placehold.co/1280x720?text=No+Backdrop"


# Pagination
VITE_DEFAULT_PAGE_SIZE=24

# Timeouts
VITE_API_TIMEOUT=20000

# Feature Flags
VITE_ENABLE_BATCH_DOWNLOADS=true
VITE_ENABLE_SUBTITLES=true
VITE_ENABLE_PREFETCH=true
VITE_ENABLE_SEARCH_HISTORY=true

# Download Settings
VITE_DOWNLOAD_DELAY=1200
VITE_MAX_BATCH_DOWNLOADS=10

# React Query
VITE_QUERY_STALE_TIME=300000
VITE_QUERY_CACHE_TIME=600000

# Development
VITE_ENABLE_LOGS=true
VITE_ENABLE_DEVTOOLS=true