# =========================================
# Platform Environment Configuration Example
# =========================================

# ------------------------------
# App Details & SEO
# ------------------------------
VITE_APP_NAME="Your App Name"
VITE_APP_AUTHOR="Your Name/Company"
VITE_SEO_TITLE="Your Website Title"
VITE_SEO_DESCRIPTION="Your Website Description"
VITE_SEO_KEYWORDS="movies, tv series, downloads, streaming"
VITE_THEME_COLOR="#030305"
VITE_APP_ENV="development"

# ------------------------------
# Contact Information
# ------------------------------
VITE_CONTACT_EMAIL="contact@yourdomain.com"
VITE_CONTACT_PHONE="+1 234 567 8900"
VITE_WHATSAPP_NUMBER="12345678900"
VITE_GITHUB_URL="https://github.com/your-username"

# ------------------------------
# SMTP Settings (For Contact Form)
# ------------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
CONTACT_EMAIL="contact@yourdomain.com"

# ------------------------------
# API Integrations
# ------------------------------
# Movie API
VITE_API_BASE="https://movieapi.gifted.co.ke"
VITE_API_KEY="YOUR_MOVIE_API_BEARER_KEY"

# AI (OpenRouter)
VITE_OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY"
VITE_OPENROUTER_URL="https://openrouter.ai/api/v1/chat/completions"

# ------------------------------
# General Settings
# ------------------------------
VITE_FALLBACK_POSTER="https://placehold.co/600x900?text=No+Poster"
VITE_FALLBACK_BACKDROP="https://placehold.co/1280x720?text=No+Backdrop"
VITE_DEFAULT_PAGE_SIZE=24
VITE_ENABLE_BATCH_DOWNLOADS=true
VITE_ENABLE_SUBTITLES=true
